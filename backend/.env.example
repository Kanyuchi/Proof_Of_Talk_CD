# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Database (AWS RDS PostgreSQL + pgvector)
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@your-rds-endpoint.rds.amazonaws.com:5432/pot_matchmaker

# OpenAI
OPENAI_API_KEY=sk-proj-...

# AWS
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_SES_FROM_EMAIL=matches@proofoftalk.io  # Must be verified in SES
APP_PUBLIC_URL=https://meet.proofoftalk.io  # production frontend (email links use this)

# Resend (primary email provider)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Proof of Talk <team@xventures.de>   # warm domain that also receives
EMAIL_REPLY_TO=team@xventures.de                       # replies land here (blank to omit)

# Email gating — who actually receives mail. Safe default "off".
#   off       — nothing sends (deploy stays silent until flipped)
#   allowlist — only EMAIL_ALLOWLIST addresses (team testing)
#   all       — everyone (full rollout)
EMAIL_MODE=off
EMAIL_ALLOWLIST=                            # comma-separated, e.g. a@pot.io,b@pot.io

# Registration gate — True = only people already in the attendees table
# (bought a ticket / added by ops) can create a login. Set False to allow
# open self-registration.
REQUIRE_TICKET_TO_REGISTER=true

# Auth — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_STRONG_RANDOM_64_CHAR_HEX
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Enrichment (optional)
PROXYCURL_API_KEY=              # Defunct — Proxycurl sunset Jan 2025
TWITTER_BEARER_TOKEN=
CRUNCHBASE_API_KEY=

# LinkedIn — linkedin-api library (primary method, free)
# Uses your LinkedIn credentials to authenticate via Voyager API automatically
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# LinkedIn Voyager — manual cookie fallback (if linkedin-api auth fails)
# Chrome → F12 → Application → Cookies → linkedin.com
#   li_at value        → LINKEDIN_LI_AT_COOKIE
#   JSESSIONID value   → LINKEDIN_CSRF_TOKEN  (just the ajax:XXXXXXX part, no quotes)
LINKEDIN_LI_AT_COOKIE=
LINKEDIN_CSRF_TOKEN=

# Google service-account JSON for the daily speaker-sheet sync. Paste the
# entire JSON (single-line) you downloaded from GCP → IAM & Admin →
# Service Accounts → keys → "Add key" → JSON. The service account email
# must be granted Viewer on the POT26 Speakers sheet.
GOOGLE_SERVICE_ACCOUNT_JSON=

# CORS — comma-separated, add your production domain here
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://your-domain.com

# Set to False in production
DEBUG=False
